ENVIRONMENT=dev

# Static token — must match the "token" field in Moodle AI Grader plugin settings.
API_TOKEN=change-me-to-something-secret

# PostgreSQL
POSTGRES_HOST=database
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=assessor

# Redis / Celery
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_BROKER_DB=0
REDIS_PASSWORD=

# LLM agent service (internal Docker network address)
LLM_AGENT_URL=http://llm-agent:8001

# Logging
LOG_LEVEL=INFO
